# =============================================================================
# Core API Keys
# =============================================================================

# OpenAI API Key (required for RAG and chat functionality)
OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE

# Admin API Key for protected endpoints (e.g., /api/ingest)
# Generate a secure key with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
ADMIN_API_KEY=CHANGE_ME_generate_a_secure_key_here


# =============================================================================
# Escalation Method
# =============================================================================

# How to handle customer escalations: "email" (default) or "zendesk"
ESCALATION_METHOD=email


# =============================================================================
# MailerSend Email Integration (when ESCALATION_METHOD=email)
# =============================================================================
# Escalation email goes out via the MailerSend HTTP API (no SMTP server needed).

# Email address to send FROM (a verified MailerSend sender)
SMTP_FROM_EMAIL=chatbotGCG@test-2p0347z05nplzdrn.mlsender.net

# MailerSend API key (from https://app.mailersend.com/api-tokens)
MAILERSEND_API_KEY=mlsn.YOUR_KEY_HERE

# Email address to send escalation emails TO (the support inbox)
SMTP_TO_EMAIL=klantenservice@groundcovergroup.nl


# =============================================================================
# Zendesk Integration (when ESCALATION_METHOD=zendesk)
# =============================================================================

# Zendesk subdomain (e.g., 'yourcompany' for yourcompany.zendesk.com)
ZENDESK_SUBDOMAIN=your-subdomain

# Zendesk account email address
ZENDESK_EMAIL=your-email@example.com

# Zendesk API token (generate from Admin -> API settings)
ZENDESK_API_TOKEN=your-zendesk-api-token-here


# =============================================================================
# CORS Configuration
# =============================================================================

# Allowed origins for CORS (comma-separated list)
# Update this with your production domain(s)
ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000


# =============================================================================
# Admin Portal Database (Feature 30a)
# =============================================================================

# Path to the SQLite database for admin portal metadata
# Default: backend/data/portal.db
# PORTAL_DB_PATH=backend/data/portal.db


# =============================================================================
# Flask Configuration
# =============================================================================

# Enable Flask debug mode (only for development!)
FLASK_DEBUG=false

# Flask environment (development/production)
FLASK_ENV=production


# =============================================================================
# Data Retention (GDPR)
# =============================================================================

# How many days to retain session data before automatic deletion
DATA_RETENTION_SESSIONS_DAYS=30

# How many days to retain chat logs before automatic deletion
DATA_RETENTION_LOGS_DAYS=90


# =============================================================================
# Model Configuration (Feature 10)
# =============================================================================

# OpenAI chat model to use for conversations
OPENAI_CHAT_MODEL=gpt-5.4-mini

# OpenAI embedding model for RAG (vector search)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small


# =============================================================================
# RAG Configuration (Feature 13)
# =============================================================================

# Distance threshold for RAG relevance filtering (lower = more strict)
# Results with distance > threshold are filtered out
RAG_RELEVANCE_THRESHOLD=1.2


# =============================================================================
# Brand Configuration
# =============================================================================

# Core brand identity
BRAND_NAME=GroundCoverGroup
BRAND_PRODUCT_LINE=GroundCoverGroup
BRAND_ASSISTANT_NAME=GroundCoverGroup

# Relevant topics (comma-separated list)
BRAND_RELEVANT_TOPICS=tuinieren, GroundCoverGroup, producten, gardening, products

# Welcome messages
BRAND_WELCOME_NL=Hallo! Waar kan ik je vandaag mee helpen?
BRAND_WELCOME_EN=Hello! I'm the GroundCoverGroup assistant. How can I help you?

# Support header text
BRAND_SUPPORT_HEADER=GroundCoverGroup Support

# Personality prompts (Dutch)
BRAND_PERSONALITY_NL=Je bent een vriendelijke, informele klantenservice-medewerker van GroundCoverGroup. Je beantwoordt vragen over onze producten en diensten alsof je een deskundige collega in de winkel bent: warm, professioneel, kort en helder. Je spreekt altijd namens wij / ons en controleert zorgvuldig voordat je antwoordt. Als je iets niet zeker weet, ben je daar eerlijk over en bied je aan dat een collega kan helpen.

# Personality prompts (English)
BRAND_PERSONALITY_EN=You are a friendly, informal customer service representative for GroundCoverGroup. You answer questions about our products and services as if you were an expert colleague in the shop: warm, professional, concise and clear. You always speak on behalf of us and check carefully before answering. If you are unsure about something, you are honest about it and offer to have a colleague assist.

# Enable emojis in responses (true/false)
BRAND_USE_EMOJIS=true



# =============================================================================
# WISMO (Where Is My Order?) Zapier Webhook
# =============================================================================

# Zapier webhook URL to verify a Shopify order number + email combination
ZAPIER_WEBHOOK_URL_WISMO=https://hooks.zapier.com/hooks/catch


# =============================================================================
# Shopify Product Availability
# =============================================================================

# Shopify store domain (e.g. your-store.myshopify.com)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Shopify Storefront API access token (public/read-only token, NOT the Admin API key)
# Generate from: Shopify Admin -> Settings -> Apps and sales channels -> Develop apps -> Storefront API
SHOPIFY_STOREFRONT_TOKEN=

# Shopify Storefront API version
SHOPIFY_API_VERSION=2024-01

# Max number of product matches to show the user before asking them to clarify (default: 3)
SHOPIFY_MAX_RESULTS=3


# =============================================================================
# Shipping / Van Den Heuvel (StatusWeb) API
# =============================================================================

# StatusWeb API Key (from Van Den Heuvel)
# Leave empty to use mock mode for testing
SHIPPING_API_KEY=

# StatusWeb Password
SHIPPING_API_PASSWORD=
